{
  "runtime": "trusted-native-canvas-v1",
  "name": "System Monitor",
  "version": "2.0.1",
  "entry": "dist/index.html",
  "homepage": "https://github.com/MyWallpapers/mywallpaper-addon-system-monitor",
  "repository": "https://github.com/MyWallpapers/mywallpaper-addon-system-monitor",
  "settings": {
    "display": {
      "type": "section",
      "label": "Displayed hardware"
    },
    "showCpu": {
      "type": "boolean",
      "label": "CPU",
      "default": true
    },
    "showMemory": {
      "type": "boolean",
      "label": "Memory",
      "default": true
    },
    "showGpu": {
      "type": "boolean",
      "label": "GPU",
      "default": true
    },
    "refreshInterval": {
      "type": "select",
      "label": "Refresh rate",
      "default": "1s",
      "options": [
        { "label": "1 second", "value": "1s" },
        { "label": "2 seconds", "value": "2s" },
        { "label": "5 seconds", "value": "5s" }
      ]
    },
    "appearance": {
      "type": "section",
      "label": "Appearance"
    },
    "backgroundColor": {
      "type": "color",
      "label": "Background",
      "default": "#10131a"
    },
    "textColor": {
      "type": "color",
      "label": "Text",
      "default": "#e7edf7"
    },
    "accentColor": {
      "type": "color",
      "label": "Accent",
      "default": "#61dafb"
    },
    "opacity": {
      "type": "range",
      "label": "Panel opacity",
      "min": 0.2,
      "max": 1,
      "step": 0.05,
      "default": 0.9
    }
  },
  "defaultLayout": {
    "xPercent": 2,
    "yPercent": 2,
    "widthPercent": 24,
    "heightPercent": 34,
    "rotation": 0
  },
  "native": {
    "companion": {
      "runtime": "process-v2",
      "entries": {
        "windows-x86_64": "native/out/windows-x86_64/bin/backend.exe",
        "windows-aarch64": "native/out/windows-aarch64/bin/backend.exe"
      }
    }
  },
  "ui": {
    "pointerEvents": "none"
  }
}
