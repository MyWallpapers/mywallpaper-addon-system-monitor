{
  "runtime": "canvas-v1",
  "name": "System Monitor",
  "description": "Shows live CPU, memory and GPU telemetry from its open-source native companion in a customizable Canvas panel.",
  "version": "3.0.0",
  "entry": "dist/index.html",
  "thumbnail": "assets/thumbnail.png",
  "deviceSettingsVersion": "1",
  "ui": {
    "pointerEvents": "none"
  },
  "settings": [
    {
      "id": "display",
      "type": "section",
      "label": "Displayed hardware"
    },
    {
      "id": "showCpu",
      "type": "boolean",
      "label": "CPU",
      "scope": "layer",
      "default": true
    },
    {
      "id": "showMemory",
      "type": "boolean",
      "label": "Memory",
      "scope": "layer",
      "default": true
    },
    {
      "id": "showGpu",
      "type": "boolean",
      "label": "GPU",
      "scope": "layer",
      "default": true
    },
    {
      "id": "refreshInterval",
      "type": "select",
      "label": "Refresh rate",
      "description": "Shared by every System Monitor instance on this device.",
      "scope": "device",
      "default": "1s",
      "options": [
        { "label": "1 second", "value": "1s" },
        { "label": "2 seconds", "value": "2s" },
        { "label": "5 seconds", "value": "5s" }
      ]
    },
    {
      "id": "appearance",
      "type": "section",
      "label": "Appearance"
    },
    {
      "id": "backgroundColor",
      "type": "color",
      "label": "Background",
      "scope": "layer",
      "default": "#10131a"
    },
    {
      "id": "textColor",
      "type": "color",
      "label": "Text",
      "scope": "layer",
      "default": "#e7edf7"
    },
    {
      "id": "accentColor",
      "type": "color",
      "label": "Accent",
      "scope": "layer",
      "default": "#61dafb"
    },
    {
      "id": "opacity",
      "type": "range",
      "label": "Panel opacity",
      "scope": "layer",
      "min": 0.2,
      "max": 1,
      "step": 0.05,
      "default": 0.9
    }
  ],
  "native": {
    "companion": {
      "runtime": "process-v2",
      "entries": {
        "windows-x86_64": "native/out/windows-x86_64/bin/backend.exe",
        "windows-aarch64": "native/out/windows-aarch64/bin/backend.exe"
      }
    }
  }
}
